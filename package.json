{
  "name": "holepunch-module-template",
  "version": "0.0.0",
  "description": "Template for a Holepunch-style npm module",
  "main": "index.js",
  "files": [
    "index.js",
    "lib/**.js"
  ],
  "scripts": {
    "format": "prettier --write .",
    "lint": "prettier --check . && lunte",
    "test": "npm run test:node && npm run test:bare",
    "test:node": "brittle-node test/all.js",
    "test:bare": "brittle-bare test/all.js",
    "test:generate": "brittle -r test/all.js test/*.js"
  },
  "devDependencies": {
    "brittle": "^3.1.0",
    "lunte": "^1.3.0",
    "prettier": "^3.6.2",
    "prettier-config-holepunch": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/connor56/holepunch-module-template.git"
  },
  "author": "Your Name",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/connor56/holepunch-module-template/issues"
  },
  "homepage": "https://github.com/connor56/holepunch-module-template"
}
